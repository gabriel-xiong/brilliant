VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional for `npm run seed:firestore`.
# If omitted, the seed script will look for ./serviceaccount.json.
FIREBASE_SERVICE_ACCOUNT_PATH=serviceaccount.json

# Set to exactly "true" to enable AI features (adaptive AI-authored practice +
# tutoring prose) for signed-in users. Off by default.
VITE_AI_ENABLED=false

# URL of the deployed Vercel serverless AI proxy (`api/aiGenerate.ts`).
# Leave blank to keep AI calls off (client uses the deterministic generator).
# After deploying, set to e.g. https://<project>.vercel.app/api/aiGenerate
VITE_AI_ENDPOINT=

# ---------------------------------------------------------------------------
# SERVER env vars — set these on Vercel (Project Settings -> Environment
# Variables), NOT in this client .env. The AI compute now runs as a Vercel
# serverless function; Firebase Hosting/Auth/Firestore stay on the free plan.
# ---------------------------------------------------------------------------
# AI_API_KEY                 (required) OpenAI-compatible API key (plain env var).
# FIREBASE_SERVICE_ACCOUNT_JSON (required) Full service-account key JSON as a
#                            single-line string; used by firebase-admin to verify
#                            ID tokens and read/write Firestore rate limits.
# AI_MODEL                   (optional) default gpt-4o-mini
# AI_BASE_URL                (optional) default https://api.openai.com/v1
# ALLOWED_ORIGIN             (optional) CORS allow-origin; default * (set to your
#                            Firebase Hosting origin to lock it down).
