rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isNullableString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isLocalDateString(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isMasteryStatus(value) {
      return value in ['not-started', 'in-progress', 'almost-done', 'completed', 'mastered'];
    }

    function isValidUserSummary(data) {
      return data.keys().hasOnly([
          'displayName',
          'email',
          'createdAt',
          'lastLoginAt',
          'lastActiveDate',
          'currentStreak',
          'longestStreak',
          'masterySummary'
        ])
        && (!('displayName' in data) || isNullableString(data.displayName, 120))
        && (!('email' in data) || isNullableString(data.email, 254))
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('lastLoginAt' in data) || data.lastLoginAt is timestamp)
        && data.lastActiveDate is string
        && isLocalDateString(data.lastActiveDate)
        && data.currentStreak is int
        && data.currentStreak >= 0
        && data.currentStreak <= 10000
        && data.longestStreak is int
        && data.longestStreak >= 0
        && data.longestStreak <= 10000
        && data.masterySummary is map
        && data.masterySummary.keys().size() <= 50;
    }

    function isValidProgress(data, lessonId) {
      return data.keys().hasOnly([
          'lessonId',
          'contentVersion',
          'lastStepIndex',
          'completed',
          'score',
          'masteryStatus',
          'stepAttempts',
          'updatedAt'
        ])
        && data.lessonId == lessonId
        && (!('contentVersion' in data) || (data.contentVersion is int && data.contentVersion >= 1 && data.contentVersion <= 1000))
        && data.lastStepIndex is int
        && data.lastStepIndex >= 0
        && data.lastStepIndex <= 100
        && data.completed is bool
        && data.score is number
        && data.score >= 0
        && data.score <= 1
        && isMasteryStatus(data.masteryStatus)
        && data.stepAttempts is map
        && data.stepAttempts.keys().size() <= 100
        && data.updatedAt is string
        && data.updatedAt.size() <= 40;
    }

    function isValidCachedProblem(data) {
      return data.conceptId is string
        && data.conceptId.size() <= 40
        && data.prompt is string
        && data.prompt.size() <= 1000
        && data.acceptedAnswer is string
        && data.acceptedAnswer.size() <= 64
        && data.params is map
        && data.params.size() <= 12
        && data.source is string
        && data.source in ['deterministic', 'ai'];
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false;
    }

    // Cache of verified, AI-authored practice problems (Phase 1).
    //
    // The answer key in each doc is ALWAYS deterministic (recomputed client-side
    // by `solveConcept`), and grading never trusts the cache blindly, so a shared
    // read/write cache among signed-in learners is safe. Writes are validated and
    // size-capped; `rateLimits/{uid}` (written only by the Cloud Function via the
    // Admin SDK, which bypasses these rules) stays denied to all clients by the
    // default-deny fall-through.
    match /problems/{problemId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && isValidCachedProblem(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserSummary(request.resource.data);
      allow delete: if false;

      match /progress/{lessonId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProgress(request.resource.data, lessonId);
        allow delete: if false;
      }
    }
  }
}
